@page
@model IndexModel
@{
    ViewData["Title"] = "Color transform demo";
    var hasOutput = !string.IsNullOrEmpty(Model.OutputColor);
}

<h1 class="mb-4">Color transform demo</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning" role="alert">@Model.ErrorMessage</div>
}

<div class="card transform-demo" style="max-width: 36rem;">
    <div class="card-header">Transform a color</div>
    <div class="card-body">
        <form method="post">
            <fieldset class="mb-4 border-0 p-0 m-0">
                <legend class="float-none w-auto px-0 fs-6 fw-semibold mb-2">Transform</legend>
                <label asp-for="TransformType" class="form-label visually-hidden">Transform</label>
                <select asp-for="TransformType" class="form-select">
                    <option value="invert">Invert</option>
                    <option value="grayscale-average">Grayscale (Average)</option>
                    <option value="tint">Tint (white tint, 50% blend)</option>
                </select>
            </fieldset>

            <div class="row g-3 align-items-start mb-4">
                <div class="col-md-5">
                    <label asp-for="InputColor" class="form-label">Input color</label>
                    <div class="color-block">
                        <div class="d-flex align-items-center gap-2">
                            <div id="inputSwatch" class="color-swatch" style="background-color: @Model.InputColor" aria-hidden="true"></div>
                            <span id="inputHex" class="font-monospace text-body">@Model.InputColor</span>
                        </div>
                        <input type="color" asp-for="InputColor" class="form-control form-control-color" />
                    </div>
                </div>

                <div class="col-md-5">
                    <p class="form-label mb-0">Output color</p>
                    <div class="color-block">
                        <div class="d-flex align-items-center gap-2">
                            @if (hasOutput)
                            {
                                <div class="color-swatch" style="background-color: @Model.OutputColor" aria-hidden="true"></div>
                                <span class="font-monospace text-body">@Model.OutputColor</span>
                            }
                            else
                            {
                                <div class="color-swatch color-swatch--empty" aria-hidden="true"></div>
                                <span class="font-monospace text-muted">—</span>
                            }
                        </div>
                        <p class="form-text mb-0">
                            @(hasOutput ? "Result of the selected transform." : "Run transform to see the result.")
                        </p>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 w-md-auto">Apply transform</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var picker = document.querySelector('input[type="color"]');
            var swatch = document.getElementById('inputSwatch');
            var hex = document.getElementById('inputHex');
            if (!picker || !swatch || !hex) return;

            function updateInputDisplay() {
                var value = picker.value;
                swatch.style.backgroundColor = value;
                hex.textContent = value;
            }

            picker.addEventListener('input', updateInputDisplay);
            updateInputDisplay();
        })();
    </script>
}
